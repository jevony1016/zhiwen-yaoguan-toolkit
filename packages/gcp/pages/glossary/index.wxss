/* 页面 */
.page {
  min-height: 100vh;
  background: #f2f2f7;
}

/* 搜索头部 */
.searchHeader {
  padding: 24rpx 32rpx;
  background: #f2f2f7;
}

.searchBar {
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  height: 96rpx;
  background: #e5e5ea;
  border-radius: 28rpx;
}

.searchIcon {
  font-size: 34rpx;
  margin-right: 16rpx;
}

.searchInput {
  flex: 1;
  height: 96rpx;
  background: transparent;
  font-size: 32rpx;
  color: #000000;
}

.searchBtn {
  color: #007aff;
  font-size: 32rpx;
  font-weight: 600;
  padding-left: 24rpx;
}

/* 分类标签 */
.categoryScroll {
  white-space: nowrap;
  padding: 0 32rpx 28rpx;
}

.categoryTags {
  display: inline-flex;
  gap: 16rpx;
}

.categoryTag {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  background: #ffffff;
  border-radius: 999rpx;
  color: #007aff;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.categoryTag.active {
  background: #007aff;
  color: #ffffff;
}

/* 结果统计 */
.resultCount {
  padding: 20rpx 40rpx;
  color: #8e8e93;
  font-size: 28rpx;
}

/* 结果列表 */
.resultList {
  background: #ffffff;
  margin: 0 32rpx 32rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.04);
}

.resultItem {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f2f2f7;
  transition: background 0.2s;
}

.resultItem:last-child {
  border-bottom: none;
}

.resultItem:active {
  background: #f7f7f7;
}

.resultLeft {
  flex-shrink: 0;
}

.abbrBadge {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 64rpx;
  min-height: 56rpx;
  padding: 8rpx 14rpx;
  background: #007aff;
  border-radius: 14rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  line-height: 1.2;
  text-align: center;
  white-space: pre-line;
}

.resultContent {
  flex: 1;
  padding-left: 28rpx;
  min-width: 0;
}

.resultMain {
  display: flex;
  flex-direction: column;
}

.resultZh {
  color: #000000;
  font-size: 34rpx;
  font-weight: 600;
}

.resultEn {
  color: #8e8e93;
  font-size: 28rpx;
  margin-top: 6rpx;
}

.resultMeta {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.resultCategory {
  color: #8e8e93;
  font-size: 24rpx;
}

.resultSource {
  font-size: 24rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.resultSource.official {
  background: rgba(52, 199, 89, 0.12);
  color: #34c759;
}

.resultSource.common {
  background: rgba(255, 149, 0, 0.12);
  color: #ff9500;
}

.resultArrow {
  flex-shrink: 0;
  color: #c7c7cc;
  font-size: 44rpx;
  margin-left: 16rpx;
}

/* 空状态 */
.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 0;
}

.emptyIcon {
  font-size: 88rpx;
  margin-bottom: 28rpx;
}

.emptyText {
  color: #000000;
  font-size: 36rpx;
  font-weight: 600;
}

.emptyHint {
  color: #8e8e93;
  font-size: 30rpx;
  margin-top: 14rpx;
}

/* 底部 */
.pageFooter {
  padding: 40rpx;
  text-align: center;
}

.footerNote {
  color: #c7c7cc;
  font-size: 26rpx;
}
