.page {
  min-height: 100vh;
  background: #f2f2f7;
  padding: 28rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
}

.top {
  padding: 18rpx 8rpx 28rpx;
}

.title {
  display: block;
  color: #1c1c1e;
  font-size: 44rpx;
  font-weight: 800;
}

.intro {
  display: block;
  color: #636366;
  font-size: 28rpx;
  line-height: 1.6;
  margin-top: 12rpx;
}

.progressWrap {
  height: 12rpx;
  background: #e5e5ea;
  border-radius: 999rpx;
  margin-top: 30rpx;
  overflow: hidden;
}

.progressBar {
  height: 100%;
  background: linear-gradient(90deg, #5856d6 0%, #34c759 100%);
  border-radius: 999rpx;
}

.progressText {
  display: block;
  color: #8e8e93;
  font-size: 24rpx;
  margin-top: 12rpx;
  text-align: right;
}

.questionCard {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 34rpx;
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.04);
}

.questionIndex {
  display: block;
  color: #8e8e93;
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 22rpx;
}

.choicePair {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.choiceSide {
  padding: 28rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  line-height: 1.55;
  color: #1c1c1e;
}

.leftSide {
  background: rgba(88, 86, 214, 0.08);
}

.rightSide {
  background: rgba(52, 199, 89, 0.1);
}

.divider {
  color: #8e8e93;
  font-size: 24rpx;
  text-align: center;
}

.optionList {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.optionItem {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f2f2f7;
  color: #1c1c1e;
  font-size: 29rpx;
  font-weight: 600;
}

.optionItem.selected {
  background: #007aff;
  color: #ffffff;
}

.optionDot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  border: 4rpx solid #c7c7cc;
  margin-right: 18rpx;
}

.selected .optionDot {
  border-color: #ffffff;
  background: #ffffff;
}

.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.navBtn {
  flex: 1;
  height: 92rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.navBtn::after {
  border: none;
}

.primary {
  background: #007aff;
  color: #ffffff;
}

.secondary {
  background: #ffffff;
  color: #007aff;
}

.secondary[disabled] {
  color: #c7c7cc;
  background: #ffffff;
}
