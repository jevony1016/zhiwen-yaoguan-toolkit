<view class="page">
  <!-- 搜索头部 -->
  <view class="searchHeader">
    <view class="searchBar">
      <text class="searchIcon">🔍</text>
      <input
        class="searchInput"
        value="{{query}}"
        placeholder="搜索术语、MedDRA code、SOC..."
        confirm-type="search"
        bindinput="onInput"
        bindconfirm="onSearch"
      />
      <text class="searchBtn" bindtap="onSearch">搜索</text>
    </view>
  </view>

  <!-- 快捷标签 -->
  <view class="quickTags">
    <text class="quickTag" data-query="贫血" bindtap="useExample">贫血</text>
    <text class="quickTag" data-query="ALT" bindtap="useExample">ALT</text>
    <text class="quickTag" data-query="血小板" bindtap="useExample">血小板</text>
    <text class="quickTag" data-query="恶心" bindtap="useExample">恶心</text>
  </view>

  <!-- 结果统计 -->
  <view wx:if="{{searched}}" class="resultCount">
    <text>找到 {{results.length}} 条结果</text>
  </view>

  <!-- 结果列表 -->
  <view class="resultList">
    <block wx:for="{{results}}" wx:key="code">
      <view class="resultItem" data-code="{{item.code}}" bindtap="openDetail">
        <view class="resultMain">
          <text class="resultName">{{item.termZh}}</text>
          <text class="resultNameEn">{{item.termEn}}</text>
        </view>
        <view class="resultMeta">
          <text class="resultCode">{{item.code}}</text>
          <text class="resultSoc">{{item.socZh}}</text>
        </view>
        <text class="resultArrow">›</text>
      </view>
    </block>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{searched && results.length === 0}}" class="emptyState">
    <text class="emptyIcon">🔍</text>
    <text class="emptyText">没有找到结果</text>
    <text class="emptyHint">试试其他关键词</text>
  </view>

  <!-- 底部说明 -->
  <view class="pageFooter">
    <text class="footerNote">数据来源：CTCAE v6.0 官方标准</text>
  </view>
</view>
