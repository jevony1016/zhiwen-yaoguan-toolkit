.page {
  padding: 34rpx 30rpx 52rpx;
}

.header {
  padding: 24rpx 4rpx 10rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 8rpx;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 650;
}

.title {
  display: block;
  color: #172033;
  font-size: 44rpx;
  font-weight: 760;
  line-height: 1.25;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.45;
}

.searchPanel {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 26rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(30, 58, 95, 0.06);
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(31, 50, 74, 0.07);
}

.searchInput {
  flex: 1;
  min-width: 0;
  height: 78rpx;
  padding: 0 22rpx;
  border: 0;
  border-radius: 20rpx;
  background: #f4f7fb;
  color: #172033;
  font-size: 28rpx;
  line-height: 78rpx;
}

.searchButton {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 130rpx;
  height: 78rpx;
  margin: 0;
  padding: 0;
  border-radius: 20rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 78rpx;
}

.searchButton::after {
  border: 0;
}

.examplesBlock {
  margin-top: 24rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(30, 58, 95, 0.05);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
}

.examples {
  display: flex;
  flex-wrap: wrap;
  align-items: stretch;
  gap: 14rpx;
  margin-top: 16rpx;
}

.examplesLabel {
  display: block;
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 600;
}

.exampleButton {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 134rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  border-radius: 999rpx;
  background: #eef4ff;
  color: #1d4ed8;
  font-size: 24rpx;
  font-weight: 560;
  line-height: 1;
  text-align: center;
}

.summary {
  margin: 28rpx 0 16rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.resultItem {
  margin-bottom: 18rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(30, 58, 95, 0.06);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 34rpx rgba(31, 50, 74, 0.06);
}

.resultTop {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.termZh {
  flex: 1;
  color: #172033;
  font-size: 32rpx;
  font-weight: 750;
  line-height: 1.35;
}

.code {
  flex: none;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #2563eb;
  font-size: 24rpx;
}

.termEn {
  display: block;
  margin-top: 8rpx;
  color: #374151;
  font-size: 27rpx;
  line-height: 1.4;
}

.socLine {
  margin-top: 14rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.socEn {
  display: block;
  margin-top: 4rpx;
}
