page {
  min-height: 100vh;
  background: #f5f5f7;
  color: #1d1d1f;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view,
text,
input {
  box-sizing: border-box;
}

.muted {
  color: #6e6e73;
}

.disclaimer {
  margin: 22rpx 0;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(0, 122, 255, 0.14);
  border-radius: 18rpx;
  background: rgba(0, 122, 255, 0.08);
  color: #24506f;
  font-size: 24rpx;
  line-height: 1.55;
}
