<view class="page">
  <!-- 顶部 Logo 区域 -->
  <view class="header">
    <view class="logoWrap">
      <image class="logo" src="/assets/logo.png" mode="aspectFit" />
    </view>
    <text class="title">知闻药观小工具</text>
    <text class="subtitle">医药人的随身工具箱</text>
  </view>

  <!-- 工具列表 -->
  <view class="section">
    <text class="sectionTitle">工具</text>
    <view class="toolList">
      <!-- CTCAE -->
      <view class="toolCard" data-path="{{tools[0].path}}" bindtap="openTool">
        <view class="toolIconWrap">
          <view class="toolIcon icon-ctcae">
            <view class="iconSymbol">
              <view class="iconBar bar1"></view>
              <view class="iconBar bar2"></view>
              <view class="iconBar bar3"></view>
            </view>
          </view>
        </view>
        <view class="toolInfo">
          <text class="toolName">CTCAE v6.0</text>
          <text class="toolDesc">不良事件分级标准查询</text>
        </view>
        <view class="toolMeta">
          <text class="toolCount">850 条</text>
          <text class="toolArrow">›</text>
        </view>
      </view>

      <!-- 缩略语词典 -->
      <view class="toolCard" data-path="{{tools[1].path}}" bindtap="openTool">
        <view class="toolIconWrap">
          <view class="toolIcon icon-glossary">
            <view class="iconBook">
              <view class="bookSpine"></view>
              <view class="bookPage"></view>
            </view>
          </view>
        </view>
        <view class="toolInfo">
          <text class="toolName">缩略语词典</text>
          <text class="toolDesc">临床试验常用术语对照</text>
        </view>
        <view class="toolMeta">
          <text class="toolCount">189 条</text>
          <text class="toolArrow">›</text>
        </view>
      </view>

      <!-- 人格小测 -->
      <view class="toolCard" data-path="{{tools[2].path}}" bindtap="openTool">
        <view class="toolIconWrap">
          <view class="toolIcon icon-personality">
            <view class="iconPulse">
              <view class="pulseDot dot1"></view>
              <view class="pulseDot dot2"></view>
              <view class="pulseDot dot3"></view>
              <view class="pulseLine"></view>
            </view>
          </view>
        </view>
        <view class="toolInfo">
          <text class="toolName">人格小测</text>
          <text class="toolDesc">通用 16 型人格与临研人 SBTI</text>
        </view>
        <view class="toolMeta">
          <text class="toolCount">2 项</text>
          <text class="toolArrow">›</text>
        </view>
      </view>

    </view>
  </view>

  <!-- 关于 -->
  <view class="section">
    <text class="sectionTitle">关于</text>
    <view class="aboutCard">
      <view class="aboutRow" bindtap="openWechat">
        <view class="aboutIconWrap">
          <view class="aboutIcon icon-wechat">
            <text class="wechatEmoji">📖</text>
          </view>
        </view>
        <view class="aboutInfo">
          <text class="aboutLabel">公众号</text>
          <text class="aboutValue">知闻药观</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 数据来源说明 -->
  <view class="sourceNote">
    <text class="sourceText">数据来源：ICH、FDA、EMA 等官方文档原文</text>
    <text class="sourceText">行业术语仅供参考学习</text>
  </view>

  <!-- 底部 -->
  <view class="footer">
    <text class="footerText">仅供学习参考，不构成医学建议</text>
  </view>
</view>
